# ══════════════════════════════════════════════════════════════════════════
#  Replay MVP — Backend · Exemplo de .env
# ══════════════════════════════════════════════════════════════════════════
#  Copie esse arquivo pra backend/.env e preencha os valores reais.
#  O arquivo .env real é ignorado pelo git (.gitignore).
# ══════════════════════════════════════════════════════════════════════════


# ── 1 ⋅ CORS + sessão cross-site ──────────────────────────────────────────
# Domínios onde o FRONTEND roda (separados por vírgula, SEM barra no final).
# Obrigatório em produção pra fetch() funcionar cross-site.
#
# Em DEV local: deixe em branco. O Vite proxy resolve tudo em localhost.
# Em PROD: liste o domínio do EasyPanel (ou seu domínio próprio).
FRONTEND_ORIGINS=https://replay.seudominio.com

# Cookie de sessão cross-site:
#   SESSION_COOKIE_SAMESITE=Lax  + SECURE=0  → DEV local (http)
#   SESSION_COOKIE_SAMESITE=None + SECURE=1  → PROD (https obrigatório)
SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=1


# ── 2 ⋅ Flask ─────────────────────────────────────────────────────────────
# Use uma string longa, aleatória, única por ambiente.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string


# ── 3 ⋅ Captura de vídeo ──────────────────────────────────────────────────
BUFFER_SECONDS=60
CAPTURE_FPS=30
CAMERA_INDICES=0,1,2,3
PREFER_SUBSTREAM=0


# ── 4 ⋅ Câmeras IP (Intelbras) ────────────────────────────────────────────
CAMERA_USER=admin
CAMERA_PASSWORD=change-me


# ── 5 ⋅ Trigger de hardware ───────────────────────────────────────────────
# Se preenchido, o ESP precisa mandar header X-Trigger-Token pra /botao
# aceitar. Vazio = aceita qualquer requisição (OK na LAN privada).
TRIGGER_TOKEN=


# ── 6 ⋅ Auto-scan ─────────────────────────────────────────────────────────
SCAN_INTERVAL=15
INACTIVE_TIMEOUT=120
